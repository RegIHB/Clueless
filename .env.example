# Supabase (Postgres + Auth). Run `supabase/migrations/20260429120000_init_wardrobe.sql` in the SQL editor.
# Enable Authentication → Providers → Anonymous sign-ins for the default app flow.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stylist chat: openai | gemini. If AI_PROVIDER is unset, only GEMINI_API_KEY → gemini; only OPENAI_API_KEY → openai.
AI_PROVIDER=openai
OPENAI_API_KEY=
# Google AI Studio (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional; default gemini-2.0-flash works on the free tier. Try gemini-2.5-flash if your project lists it.
# GEMINI_MODEL=gemini-2.0-flash
# Optional: in-app product image search (Programmable Search Engine + Custom Search JSON API).
# If unset, the app uses Openverse for picker results.
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
REPLICATE_API_TOKEN=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
