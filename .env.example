# --- Supabase (required for cloud persistence: wardrobe + saved outfits) ---
# 1. Create a project at https://supabase.com/dashboard
# 2. Project Settings → API: copy "Project URL" and "anon public" key into .env.local (not this file).
# 3. SQL Editor → New query → paste full contents of supabase/migrations/20260429120000_init_wardrobe.sql → Run.
#    If the trigger fails, change the last line to: execute function public.handle_new_user ();
# 4. Authentication → Providers → Email: enable; turn on “Confirm email” only if you want verification before sign-in.
#    Site URL: your app origin (e.g. http://localhost:3000). Add the same under Redirect URLs.
#    Optional: disable Anonymous sign-ins if you only want email accounts.
# 5. Restart Next.js (`npm run dev`). Saved outfits then sync per auth user.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stylist chat: openai | gemini. If AI_PROVIDER is unset, only GEMINI_API_KEY → gemini; only OPENAI_API_KEY → openai.
AI_PROVIDER=openai
OPENAI_API_KEY=
# Google AI Studio (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional; default gemini-2.0-flash works on the free tier. Try gemini-2.5-flash if your project lists it.
# GEMINI_MODEL=gemini-2.0-flash
# Wardrobe “Add item” product search (recommended — matches google_shopping in sibling Clueless app):
# https://serpapi.com — set SERPAPI_KEY for reliable clothing/product thumbnails.
SERPAPI_KEY=
# Optional fallback: Google Programmable Search (image search).
GOOGLE_CUSTOM_SEARCH_API_KEY=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
# If neither SerpApi nor Google is set, Openverse is used (CC images; can be rate-limited).
# Virtual try-on (Replicate). Token: replicate.com/account/api-tokens — runs use paid GPU credit (replicate.com/account/billing).
REPLICATE_API_TOKEN=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
