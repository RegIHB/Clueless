# Stylist chat: openai | gemini. If AI_PROVIDER is unset, only GEMINI_API_KEY → gemini; only OPENAI_API_KEY → openai.
AI_PROVIDER=openai
OPENAI_API_KEY=
# Google AI Studio (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional; default gemini-2.0-flash works on the free tier. Try gemini-2.5-flash if your project lists it.
# GEMINI_MODEL=gemini-2.0-flash
REPLICATE_API_TOKEN=
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
